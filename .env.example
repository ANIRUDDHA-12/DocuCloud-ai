# Environment Variables Template — DocuCloud AI
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to git. It is already listed in .gitignore.

# ------------------------------------------------------------------
# Supabase Configuration
# Find these in: Supabase Dashboard → Settings → API
# ------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here
# Service role key — NEVER expose to the browser, server-side only
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# ------------------------------------------------------------------
# Google Gemini API Key
# Get your key at: https://aistudio.google.com/app/apikey
# NOTE: This key is used ONLY in the Vercel serverless function (api/extract.js).
# It is NOT exposed to the browser (no VITE_ prefix).
# ------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-api-key-here
